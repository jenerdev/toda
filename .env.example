# Copy to .env.local and fill in from your Supabase project (Settings -> API).
# These VITE_ vars are bundled into the frontend and are safe to be public.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Web Push (driver ride-offer notifications). The VAPID *public* key is safe to
# ship in the client. Generate a keypair with `npx web-push generate-vapid-keys`
# and put the PUBLIC key here; the PRIVATE key goes only in the notify-driver
# Edge Function's secrets (never in the frontend).
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# NOTE: the service role key is SERVER-ONLY (Edge Functions).
# It must NEVER be prefixed with VITE_ or used in frontend code.
