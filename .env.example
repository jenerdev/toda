# Copy to .env.local and fill in from your Supabase project (Settings -> API).
# These VITE_ vars are bundled into the frontend and are safe to be public.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# NOTE: the service role key is SERVER-ONLY (Edge Functions).
# It must NEVER be prefixed with VITE_ or used in frontend code.
